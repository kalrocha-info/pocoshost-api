# ============================================
# VARIÁVEIS DE AMBIENTE - PRODUÇÃO
# ============================================
# Copie este arquivo para .env na Hostinger
# e preencha com os valores reais.
# ============================================

# Ambiente
NODE_ENV=production
PORT=3001

# ============================================
# BANCO DE DADOS (escolha UMA opção)
# ============================================

# OPÇÃO 1: DATABASE_URL (Neon/Supabase/Railway)
# Formato: postgresql://usuario:senha@host/database?sslmode=require
DATABASE_URL=postgresql://seu_usuario:sua_senha@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# OPÇÃO 2: Variáveis individuais (se não usar DATABASE_URL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=pocoshost
# DB_USER=pocoshost
# DB_PASSWORD=sua_senha_segura

# ============================================
# AUTENTICAÇÃO
# ============================================

# JWT Secret - MÍNIMO 32 caracteres, use um gerador seguro
# Exemplo: openssl rand -base64 32
JWT_SECRET=GERE_UMA_CHAVE_SEGURA_COM_MINIMO_32_CARACTERES

# ============================================
# CORS - Domínios permitidos
# ============================================

# Separe múltiplos domínios por vírgula
CORS_ORIGIN=https://pocoshost.com.br,https://www.pocoshost.com.br

# ============================================
# ASAAS - Pagamentos (quando implementar)
# ============================================

# Sandbox (testes)
# ASAAS_API_KEY=$aact_YTU5YTE0M2M2N2I4MTliNzk0YTI5N2U5MzdjNWZmNDQ6OjAwMDAwMDAwMDAwMDAwMDAwMDA6OiRhYWNoXzEyMzQ1Njc4OTAxMjM0NTY3ODkwMTIzNA==
# ASAAS_API_URL=https://sandbox.asaas.com/api/v3

# Produção (quando aprovado)
# ASAAS_API_KEY=$aact_SuaChaveDeProducao
# ASAAS_API_URL=https://api.asaas.com/api/v3

# Webhook Secret (gerado pelo ASAAS)
# ASAAS_WEBHOOK_SECRET=seu_webhook_secret

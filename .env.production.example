# ============================================
# VARIÁVEIS DE AMBIENTE - PRODUÇÃO
# ============================================
# Copie este arquivo para .env na Hostinger
# e preencha com os valores reais.
# ============================================

# Ambiente
NODE_ENV=production
PORT=3001

# ============================================
# BANCO DE DADOS (escolha UMA opção)
# ============================================

# OPÇÃO 1: DATABASE_URL (Neon/Supabase/Railway)
# Formato: postgresql://usuario:senha@host/database?sslmode=require
DATABASE_URL=postgresql://seu_usuario:sua_senha@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# OPÇÃO 2: Variáveis individuais (se não usar DATABASE_URL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=pocoshost
# DB_USER=pocoshost
# DB_PASSWORD=sua_senha_segura

# ============================================
# AUTENTICAÇÃO
# ============================================

# JWT Secret - MÍNIMO 32 caracteres, use um gerador seguro
# Exemplo: openssl rand -base64 32
JWT_SECRET=GERE_UMA_CHAVE_SEGURA_COM_MINIMO_32_CARACTERES

# ============================================
# CORS - Domínios permitidos
# ============================================

# Separe múltiplos domínios por vírgula
CORS_ORIGIN=https://pocoshost.com,https://www.pocoshost.com,https://firebrick-lemur-458939.hostingersite.com

# URL pública usada nos links transacionais, incluindo /verify-email?token=...
FRONTEND_URL=https://pocoshost.com

# ============================================
# ASAAS - Pagamentos (quando implementar)
# ============================================

# Sandbox (testes)
# ASAAS_API_KEY=$aact_YTU5YTE0M2M2N2I4MTliNzk0YTI5N2U5MzdjNWZmNDQ6OjAwMDAwMDAwMDAwMDAwMDAwMDA6OiRhYWNoXzEyMzQ1Njc4OTAxMjM0NTY3ODkwMTIzNA==
# ASAAS_API_URL=https://api-sandbox.asaas.com/v3

# Produção (quando aprovado)
# ASAAS_API_KEY=$aact_SuaChaveDeProducao
# ASAAS_API_URL=https://api.asaas.com/v3

# Sandbox (recomendado até homologação completa)
ASAAS_API_URL=https://api-sandbox.asaas.com/v3
ASAAS_API_KEY=sua_chave_sandbox_asaas
ASAAS_WEBHOOK_TOKEN=token_que_voce_define_no_webhook_asaas
ASAAS_PLATFORM_FEE_PERCENT=15.5
# Cada anfitrião deve ter users.asaas_wallet_id preenchido com sua wallet Asaas.

# Produção (após aprovação Asaas)
# ASAAS_API_URL=https://api.asaas.com/v3
# ASAAS_API_KEY=sua_chave_producao_asaas

# ============================================
# CLOUDINARY - Upload de imagens
# ============================================
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key_numerica
CLOUDINARY_API_SECRET=seu_api_secret

# ============================================
# SMTP - Envio de E-mails (FEAT-004)
# ============================================
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contato@pocoshost.com
SMTP_PASS=sua_senha_smtp_aqui
SMTP_FROM="PoçosHost <contato@pocoshost.com>"
